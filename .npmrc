# pnpm v11+ configuration
# Allow build scripts for packages that need postinstall
onlyBuiltDependencies[]=electron
onlyBuiltDependencies[]=@ffmpeg-installer/ffmpeg
onlyBuiltDependencies[]=electron-builder

# Use npmmirror for faster downloads in China
registry=https://registry.npmmirror.com
electron_mirror=https://npmmirror.com/mirrors/electron/
