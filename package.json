{
  "name": "douyin-live-recorder",
  "version": "1.0.0",
  "description": "抖音直播录制工具 - 自动录制直播画面、弹幕及礼物特效",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "preview": "npx serve src -l ${DEPLOY_RUN_PORT}"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "@ffmpeg-installer/ffmpeg",
      "electron-builder"
    ]
  },
  "build": {
    "appId": "com.douyin.recorder",
    "productName": "抖音直播录制",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "抖音直播录制"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*"
    ]
  }
}
