{
  "name": "douyin-live-recorder",
  "version": "1.0.0",
  "description": "抖音直播录制工具 - 自动录制直播画面、弹幕及礼物特效",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "preview": "npx serve src -l ${DEPLOY_RUN_PORT}"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.0",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.douyin.recorder",
    "productName": "DouyinLiveRecorder",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffprobe-installer/**/*",
      "node_modules/fluent-ffmpeg/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "抖音直播录制",
      "include": "build/uninstaller.nsh"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/**/*",
      "node_modules/**/*"
    ]
  }
}
